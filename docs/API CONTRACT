  "communityCards": [],
  "totalPot": 200,
  "status": "IN_PROGRESS"
}
```

**POST /poker/river — Response:**
```json
{
  "sessionId": "uuid",
  "playerCards": ["AS", "KH"],
  "dealerCards": ["7D", "9C"],
  "communityCards": ["QS", "JH", "10D", "2C", "5H"],
